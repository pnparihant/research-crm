# ── MongoDB ───────────────────────────────────────────────────────────────────
# External DB server — do NOT use localhost
MONGODB_URI=mongodb://172.17.24.16:27017/research_crm

# ── Seed admin (only used by scripts/seed-admin.js on first run) ──────────────
ADMIN_EMAIL=admin@arihantcapital.com
ADMIN_PASSWORD=change_me_strong_password
ADMIN_NAME=Admin

# ── MSSQL (stock data) ────────────────────────────────────────────────────────
MSSQL_HOST=172.17.11.12
MSSQL_DB=commondb
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_PORT=1433

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
NEXTAUTH_SECRET=replace_with_32_byte_hex_secret
# Must match the public URL of the app — no trailing slash
NEXTAUTH_URL=https://uat-crmnxt.arihantcapital.com

# ── SMTP (email OTP + password reset) ────────────────────────────────────────
SMTP_HOST=smtp.zatpatmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=emailapikey
SMTP_PASS=
SMTP_FROM=noreply@arihantcapital.com
SMTP_FROM_NAME=Arihant Capital Markets

# ── Arihant SMS API (mobile OTP) ─────────────────────────────────────────────
